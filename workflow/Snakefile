# -------------------
# REPORT
# -------------------
rule report:
    input:
        rf=f"{RESULTS}/tree_comparison/rf_all.txt",
        summary=f"{RESULTS}/tree_comparison/comparison_summary.txt"
    output:
        f"{RESULTS}/report/phylogenetic_analysis_report.txt"
    shell:
        """
        mkdir -p {RESULTS}/report
        echo "Phylogenetic analysis completed" > {output}
        echo "" >> {output}
        echo "=== RF DISTANCES ===" >> {output}
        cat {input.rf} >> {output}
        echo "" >> {output}
        echo "=== SUMMARY ===" >> {output}
        cat {input.summary} >> {output}
        """